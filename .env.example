PROJECT_NAME=NAS Access Audit Platform
APP_ENV=development

POSTGRES_DB=naap
POSTGRES_USER=naap_app
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://naap_app:change_me@postgres:5432/naap

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
JWT_SECRET_KEY=change_this_secret
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

NAS_HOST=nas.internal.local
NAS_PORT=22
NAS_USERNAME=svc_naap
NAS_PASSWORD=change_me
NAS_PRIVATE_KEY_PATH=
NAS_TIMEOUT=10
NAS_PASSWD_COMMAND=getent passwd
NAS_GROUP_COMMAND=getent group
NAS_SHARES_COMMAND=ls /volume1
NAS_ACL_COMMAND_TEMPLATE=synoacltool -get /volume1/{share}
SYNC_LIVE_MAX_ATTEMPTS=3
SYNC_LIVE_RETRY_DELAY_SECONDS=2
SYNC_LIVE_BACKOFF_MODE=fixed
SYNC_LIVE_BACKOFF_MULTIPLIER=2
SYNC_LIVE_BACKOFF_MAX_DELAY_SECONDS=30
SYNC_LIVE_BACKOFF_JITTER_ENABLED=false
SYNC_LIVE_BACKOFF_JITTER_RATIO=0.2
SYNC_SCHEDULE_ENABLED=false
SYNC_SCHEDULE_INTERVAL_SECONDS=900
SYNC_SCHEDULE_MAX_CYCLES=0
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin

FRONTEND_PORT=3000
API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

NGINX_PORT=8080
